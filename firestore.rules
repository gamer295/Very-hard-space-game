rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['playerName', 'score', 'level', 'createdAt', 'userId'])
        && data.keys().size() == 5
        && data.playerName is string && data.playerName.size() >= 2 && data.playerName.size() <= 15
        && data.score is int && data.score >= 0
        && data.level is int && data.level >= 1
        && data.createdAt == request.time
        && data.userId == request.auth.uid;
    }

    match /leaderboard/{scoreId} {
      // Publicly readable for leaderboard display
      allow list, get: if true;
      // Creation still requires auth
      allow create: if request.auth != null && isValidId(scoreId) && isValidScore(request.resource.data);
      allow update, delete: if false;
    }
  }
}
